---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/png' sizes='96x96' href='/favicon.png' />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
